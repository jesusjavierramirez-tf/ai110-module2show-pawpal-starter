classDiagram
    %% PawPal+ System - Final UML Diagram
    %% Phase 6: Complete system architecture after all implementation phases
    
    class Owner {
        -name: str
        -available_hours: float
        -pets: List[Pet]
        +set_availability(hours: float) void
        +get_availability() float
        +add_pet(pet: Pet) void
        +remove_pet(pet_name: str) bool
        +get_all_tasks() List[Task]
        +get_all_pending_tasks() List[Task]
    }
    
    class Pet {
        -name: str
        -breed: str
        -age: int
        -tasks: List[Task]
        +get_info() str
        +add_task(task: Task) bool
        +remove_task(task_id: str) bool
        +get_tasks() List[Task]
        +get_pending_tasks() List[Task]
        +mark_task_complete(task_id: str) Optional[Task]
    }
    
    class Task {
        -task_type: str
        -duration: float
        -priority: str
        -description: str
        -frequency: str
        -time_slot: Optional[str]
        -task_id: str
        -completed: bool
        -due_date: Optional[datetime]
        +validate() bool
        +get_duration() float
        +get_priority_level() int
        +get_time_slot_minutes() int
        +mark_complete() Optional[Task]
        +mark_incomplete() void
        +_generate_next_occurrence() Task
    }
    
    class Scheduler {
        -owner: Owner
        +get_all_tasks() List[Task]
        +get_pending_tasks() List[Task]
        +sort_by_priority(tasks: Optional[List[Task]]) List[Task]
        +sort_by_time(tasks: Optional[List[Task]]) List[Task]
        +filter_by_pet(pet_name: str) List[Task]
        +filter_by_status(completed: bool) List[Task]
        +detect_conflicts() List[Dict]
        +generate_plan(available_minutes: Optional[float]) List[Task]
        +get_daily_plan() List[Task]
        +assign_time_slots(tasks: List[Task], start_time: str) List[Task]
    }
    
    %% Key Relationships
    Owner "1" -- "*" Pet : owns
    Pet "1" -- "*" Task : contains
    Scheduler "1" -- "1" Owner : orchestrates_for
    Scheduler "1" -- "*" Task : organizes

    %% Notes on Architecture:
    %% - Owner is the root entity managing pets and availability
    %% - Pet manages its own task list with validation
    %% - Task encapsulates scheduling logic (priority, recurrence, validation)
    %% - Scheduler is the "brain" that uses algorithms to optimize plans
    %% - All classes use dataclass pattern for clean, immutable data
